rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Users can only read/write their own audio files
    match /users/{uid}/audio/{audioId} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024   // max 10 MB
                   && request.resource.contentType.matches('audio/.*');
    }

    // Space audio: any authenticated user can read space audio.
    // Only authenticated users can write (Firestore membership check not available here,
    // so we rely on Firestore rules to guard who joins a space).
    match /spaces/{spaceId}/audio/{audioId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }
  }
}
